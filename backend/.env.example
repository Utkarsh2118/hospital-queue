PORT=5000
MONGO_URI=mongodb://localhost:27017/hospital-queue
JWT_SECRET=change_this_to_a_long_random_secret
# Used to build the link inside password-reset emails (e.g. https://hospital-queue-sigma.vercel.app)
CLIENT_URL=http://localhost:5173

# Optional — if unset, forgot-password links are logged to the server
# console instead of emailed (fully functional for local/dev testing).
RESEND_API_KEY=
RESEND_FROM_EMAIL=MediQueue <onboarding@resend.dev>
